{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "id": "default",
    "models": ["claude-3-5-sonnet-20241022", "gpt-4-turbo", "gemini-pro"]
  },
  "permission": {
    "auto-approve": [
      "file.read",
      "file.write",
      "bash.run"
    ],
    "require-approval": [
      "file.delete",
      "git.commit",
      "git.push"
    ]
  },
  "plugin": [
    "oh-my-openagent",
    "opencode-plugin-selector",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "/home/dressedinblack/ponytail/.opencode/plugins/ponytail.mjs",
    "opencode-vibeguard",
    "@tarquinen/opencode-dcp@latest",
    "ecc-universal"
  ],
  "references": {
    "effect": {
      "repository": "github.com/Effect-TS/effect-smol",
      "description": "Use for Effect v4 and effect-smol implementation details"
    },
    "openaxe-local": {
      "path": "~/.local/share/openaxe",
      "description": "Contains openaxe logs and data"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "enabled": true,
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "github": {
      "type": "local",
      "enabled": true,
      "command": "npx",
      "args": ["-y", "@ildunari/github-mcp-server"]
    }
  },
  "tools": {
    "github-triage": false,
    "github-pr-search": false
  }
}
