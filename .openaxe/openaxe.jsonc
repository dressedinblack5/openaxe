{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-flash",
  "provider": {},
  "permission": {},
  "plugin": [
    "oh-my-openagent",
    "opencode-plugin-selector",
    "superpowers",
    "opencode-vibeguard",
    "@tarquinen/opencode-dcp@latest",
    "ecc-universal"
  ],
  "references": {
    "effect": {
      "repository": "github.com/Effect-TS/effect-smol",
      "description": "Use for Effect v4 and effect-smol implementation details"
    },
    "opencode-local": {
      "path": "~/.local/share/opencode",
      "description": "Contains opencode logs and data"
    }
  },
  "mcp": {
    "codegraph": {
      "type": "local",
      "enabled": true,
      "command": [
        "/home/dressedinblack/.local/bin/codegraph",
        "serve",
        "--mcp"
      ]
    },
    "context7": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "github": {
      "type": "local",
      "enabled": true,
      "command": [
        "sh",
        "-c",
        "exec npx -y @ildunari/github-mcp-server --github-token \"$(gh auth token)\""
      ]
    },
    "hermes": {
      "type": "local",
      "enabled": true,
      "command": [
        "/home/dressedinblack/.hermes/bin/hermes",
        "mcp",
        "serve"
      ]
    }
  },
  "tools": {
    "github-triage": false,
    "github-pr-search": false
  }
}