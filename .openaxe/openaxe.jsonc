{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-flash",
  "provider": {},
  "permission": {},
  "plugin": [
    "oh-my-openagent",
    "opencode-plugin-selector",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opencode-vibeguard",
    "@tarquinen/opencode-dcp@latest",
    "ecc-universal",
    "DietrichGebert/ponytail"
  ],
  "references": {
    "effect": {
      "repository": "github.com/Effect-TS/effect-smol",
      "description": "Use for Effect v4 and effect-smol implementation details"
    },
    "opencode-local": {
      "path": "~/.local/share/opencode",
      "description": "Contains opencode logs and data"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "enabled": true,
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "github": {
      "type": "local",
      "enabled": true,
      "command": "npx",
      "args": ["-y", "@ildunari/github-mcp-server"]
    }
  },
  "tools": {
    "github-triage": false,
    "github-pr-search": false
  }
}
